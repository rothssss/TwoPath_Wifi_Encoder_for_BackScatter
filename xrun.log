xcelium> source /clear/apps/cadence-2025/rhel8/XCELIUM2503/tools/xcelium/files/xmsimrc
xcelium> # =============================================================================
xcelium> # saif.tcl : dump an SAIF activity file for every signal inside the DUT
xcelium> # across the whole TB run.  Feed the resulting activity.saif into Joules
xcelium> # (Cadence) or PrimePower (Synopsys) for dynamic-power estimation.
xcelium> #
xcelium> # Usage:
xcelium> #   xrun -sv -access +rwc -f tb/filelist.f \
> #        -top tb_multi_mode_tx_baseband \
> #        -input tb/saif.tcl
xcelium> # =============================================================================
xcelium> 
xcelium> # Open an SAIF database that will capture every toggle while the sim runs.
xcelium> database -open -saif saifdb -into activity.saif -default
xmsim: *E,UNKOPT: unrecognized option for the database [-open] command (-saif).
xcelium> 
xcelium> # Probe everything under the DUT instance recursively.  `-depth all` walks
xcelium> # hierarchy; `-all` includes every net/reg/port at each level.
xcelium> probe -create -saif -database saifdb tb_multi_mode_tx_baseband.dut \
>       -all -depth all
xmsim: *E,UNKOPT: unrecognized option for the probe [-create] command (-saif).
xcelium> 
xcelium> # Run the whole testbench.  The initial block in the TB ends with $finish,
xcelium> # which closes the database automatically, but we call it explicitly for
xcelium> # clarity.
xcelium> run
